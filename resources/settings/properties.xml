<properties>
    <!-- Key dates stored as YYYYMMDD integers (e.g. 20260630 = June 30 2026).
         Using date integers avoids UTC vs. local-time ambiguity with raw Unix timestamps. -->
    <property id="OfficialEndDate" type="number">20260630</property>
    <property id="ConnectedHolidaysStart" type="number">0</property>

    <!-- School-days profile (Sun-Sat). Default: Sun-Fri true, Sat false. -->
    <property id="SchoolDaySun" type="boolean">true</property>
    <property id="SchoolDayMon" type="boolean">true</property>
    <property id="SchoolDayTue" type="boolean">true</property>
    <property id="SchoolDayWed" type="boolean">true</property>
    <property id="SchoolDayThu" type="boolean">true</property>
    <property id="SchoolDayFri" type="boolean">true</property>
    <property id="SchoolDaySat" type="boolean">false</property>

    <!-- Final bell per day (HH:MM) -->
    <!-- Times stored in UTC. Israel summer (IDT) = UTC+3, so 13:00 local = 10:00 UTC -->
    <property id="EndHourSun" type="string">10:00</property>
    <property id="EndHourMon" type="string">10:00</property>
    <property id="EndHourTue" type="string">10:00</property>
    <property id="EndHourWed" type="string">10:00</property>
    <property id="EndHourThu" type="string">10:00</property>
    <property id="EndHourFri" type="string">10:00</property>
    <property id="EndHourSat" type="string">10:00</property>
</properties>
